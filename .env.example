# Clés API (selon le provider utilisé)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIzaSy...
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Configuration Serveur
CHRYSALIDE_DEFAULT_PROVIDER=openai:gpt-4o-mini
CHRYSALIDE_FALLBACK_PROVIDER=
CHRYSALIDE_STORE_PATH=~/.chrysalide/jobs.db
CHRYSALIDE_LOG_LEVEL=INFO
CHRYSALIDE_LOG_PATH=~/.chrysalide/logs/

# Budgets
CHRYSALIDE_MAX_ITERATIONS=15
CHRYSALIDE_MAX_WALL_TIME_MIN=30
CHRYSALIDE_MAX_TOKENS_TOTAL=500000
CHRYSALIDE_MAX_FILE_SIZE_MB=1
CHRYSALIDE_SHELL_TIMEOUT_SEC=60

# Rétention
CHRYSALIDE_CLEANUP_AFTER_DAYS=7
CHRYSALIDE_CLEANUP_ENABLED=false
